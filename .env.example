# Copy to .env and fill in. .env is gitignored; this file is committed.

# ---- Gemini (server-side ONLY — never expose to the browser) ----
# Get a free key from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# ---- Firebase / Firestore ----
# Create a Firebase project, enable Firestore, create a service account,
# download the JSON key, and extract these three values from it.
FIREBASE_PROJECT_ID="your_project_id"
FIREBASE_CLIENT_EMAIL="your_service_account@your_project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ---- Tunable system-layer knobs (see lib/config.ts) ----
# Gemini models
GEMINI_VISION_MODEL="gemini-2.5-flash"
# Ordered fallback models for vision/text. Each model has its OWN free-tier daily quota
# (~20 req/day/model), so if the primary is exhausted (429) or overloaded (503) the request
# transparently falls through to the next. Comma-separated.
GEMINI_FALLBACK_MODELS="gemini-2.5-flash-lite,gemini-2.0-flash,gemini-2.0-flash-lite"
GEMINI_EMBEDDING_MODEL="gemini-embedding-001"
# Duplicate-clustering thresholds
CLUSTER_RADIUS_METERS="150"
CLUSTER_SIMILARITY_THRESHOLD="0.82"
